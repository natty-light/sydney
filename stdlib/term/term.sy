module "term"

pub extern func term_set_raw(int fd) -> result<int>;

pub extern func term_reset(int fd) -> result<int>;

pub define struct Term { fd int }

pub func make_raw(Term t) -> result<Term> {
  match term_set_raw(t.fd) {
    ok(fd) -> { ok(t); },
    err(msg) -> { err(msg); },
  };
}

pub func reset(Term t) -> result<Term> {
  match term_reset(t.fd) {
    ok(fd) -> { ok(t); },
    err(msg) -> { err(msg); },
  };
}
